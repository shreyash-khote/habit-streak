{
  "name": "frontend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "npx tailwindcss -i ./global.css -o ./assets/output.css && expo export --platform web",
    "railway:build": "npm install --legacy-peer-deps && npx tailwindcss -i ./global.css -o ./assets/output.css && npx expo export --platform web",
    "railway:start": "npx serve dist -l ${PORT:-3000}"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.12.1",
    "nativewind": "^2.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "tailwindcss": "3.3.2"
  },
  "private": true,
  "devDependencies": {
    "babel-preset-expo": "~54.0.10"
  }
}
